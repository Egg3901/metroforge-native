{
  "name": "metroforge-sim",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "start": "bun run sidecar/index.ts",
    "smoke": "bun run sidecar/smoke-test.ts",
    "test": "vitest run",
    "build-cities": "bun run scripts/run-build-cities.ts",
    "validate-scenarios": "bun run scripts/validate-scenarios.ts",
    "compile:linux": "bun build --compile --target=bun-linux-x64 ./sidecar/index.ts --outfile ../dist-sidecar/metroforge-sidecar",
    "compile:windows": "bun build --compile --target=bun-windows-x64 ./sidecar/index.ts --outfile ../dist-sidecar/metroforge-sidecar.exe",
    "compile:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 ./sidecar/index.ts --outfile ../dist-sidecar/metroforge-sidecar-darwin-arm64"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/geojson": "^7946.0.16",
    "ajv": "^8.20.0",
    "shapefile": "^0.6.6",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.8"
  }
}
